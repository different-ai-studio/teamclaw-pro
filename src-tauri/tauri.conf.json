{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TeamClaw",
  "version": "1.0.0",
  "identifier": "com.teamclaw.app",
  "build": {
    "beforeDevCommand": "pnpm --filter @teamclaw/app dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm --filter @teamclaw/app build",
    "frontendDist": "../packages/app/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "TeamClaw",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "visible": true,
        "dragDropEnabled": true,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "alwaysOnTop": false,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/**",
          "/**"
        ]
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "fs": {
      "requireLiteralLeadingDot": false
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDEzNERENUYxRTY3RDhGOEEKUldTS2ozM204ZFZORXlIemNIUnpNYnpmY1B2VmcrN1Y1YTZ2RTg2ZjJvZ2FLV3pQWGhCSloxcFUK",
      "endpoints": [
        "https://teamclaw.ucar.cc/teamclaw-pro/update.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "macOS": {
      "entitlements": "./Entitlements.plist"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/opencode"
    ]
  }
}
